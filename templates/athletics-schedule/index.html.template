<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OPSsign2 - Schedule Display</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="{THEME_PATH}">
    <style>
        /* Full-screen schedule styling */
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            background: #000;
        }

        /* Hide all UI elements for pure schedule display */
        #banner,
        #navigation,
        #footer {
            display: none !important;
        }

        /* Full-screen schedule container */
        #scheduleContainer {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: #000;
            z-index: 1;
        }

        #scheduleContainer iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
            background: #fff;
        }

        /* Loading state */
        #loadingMessage {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #fff;
            font-size: 2em;
            font-family: Arial, sans-serif;
            text-align: center;
            z-index: 2;
        }

        .spinner {
            border: 4px solid rgba(255, 255, 255, 0.3);
            border-top: 4px solid #fff;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Error state */
        #errorMessage {
            display: none;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #ff6b6b;
            font-size: 1.5em;
            font-family: Arial, sans-serif;
            text-align: center;
            z-index: 2;
            max-width: 80%;
        }

        /* Minimal device info overlay - hover to show */
        #deviceInfo {
            position: fixed;
            bottom: 0;
            right: 0;
            background: rgba(0, 0, 0, 0.7);
            color: #fff;
            padding: 5px 10px;
            font-size: 0.8em;
            font-family: Arial, sans-serif;
            z-index: 100;
            opacity: 0;
            transition: opacity 0.3s;
        }

        body:hover #deviceInfo {
            opacity: 1;
        }

        /* Alert banner styling */
        .alert-banner {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            padding: 15px;
            text-align: center;
            font-weight: bold;
            font-size: 1.2em;
            z-index: 1000;
            animation: slideDown 0.5s ease-out;
        }

        .alert-banner.priority-high {
            background: linear-gradient(135deg, #c0392b 0%, #e74c3c 100%);
            color: white;
            animation: slideDown 0.5s ease-out, pulse 2s ease-in-out infinite;
        }

        .alert-banner.priority-medium {
            background: linear-gradient(135deg, #d35400 0%, #e67e22 100%);
            color: white;
        }

        .alert-banner.priority-low {
            background: linear-gradient(135deg, #2980b9 0%, #3498db 100%);
            color: white;
        }

        @keyframes slideDown {
            from {
                transform: translateY(-100%);
            }
            to {
                transform: translateY(0);
            }
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 1;
            }
            50% {
                opacity: 0.8;
            }
        }

        /* Adjust schedule container when alert is present */
        body.has-alert #scheduleContainer {
            top: 60px;
            height: calc(100vh - 60px);
        }
    </style>
</head>
<body>
    <!-- Alert Banner (shown when alert is active) -->
    <div id="alertBanner" class="alert-banner" style="display: none;"></div>

    <!-- Loading Message -->
    <div id="loadingMessage">
        <div class="spinner"></div>
        <div>Loading Schedule...</div>
    </div>

    <!-- Error Message -->
    <div id="errorMessage">
        <div style="font-size: 3em; margin-bottom: 20px;">⚠️</div>
        <div>Unable to load schedule</div>
        <div style="font-size: 0.8em; margin-top: 10px;">Please check your connection</div>
    </div>

    <!-- Schedule Container -->
    <div id="scheduleContainer" style="display: none;">
        <iframe id="scheduleFrame"
                src="https://www.metrowestconference.org/public/genie/726/school/6949/"
                title="Athletic Schedule"
                allowfullscreen>
        </iframe>
    </div>

    <!-- Minimal Device Info -->
    <div id="deviceInfo">
        <strong>{LOCATION}</strong> | Device: {DEVICE_ID}
    </div>

    <script>
        // Configuration
        const SCHEDULE_URL = 'https://www.metrowestconference.org/public/genie/726/school/6949/';
        const deviceId = '{DEVICE_ID}';
        const location = '{LOCATION}';

        // DOM elements
        const scheduleContainer = document.getElementById('scheduleContainer');
        const scheduleFrame = document.getElementById('scheduleFrame');
        const loadingMessage = document.getElementById('loadingMessage');
        const errorMessage = document.getElementById('errorMessage');
        const alertBanner = document.getElementById('alertBanner');

        // Initialize schedule display
        function initSchedule() {
            console.log('Initializing schedule display...');
            console.log('Device ID:', deviceId);
            console.log('Location:', location);
            console.log('Schedule URL:', SCHEDULE_URL);

            // Set up iframe load handlers
            scheduleFrame.onload = function() {
                console.log('Schedule loaded successfully');
                loadingMessage.style.display = 'none';
                errorMessage.style.display = 'none';
                scheduleContainer.style.display = 'block';
            };

            scheduleFrame.onerror = function() {
                console.error('Failed to load schedule');
                loadingMessage.style.display = 'none';
                scheduleContainer.style.display = 'none';
                errorMessage.style.display = 'block';
            };

            // Fallback timeout - show schedule even if load event doesn't fire
            setTimeout(function() {
                if (loadingMessage.style.display !== 'none') {
                    console.log('Load timeout - showing schedule anyway');
                    loadingMessage.style.display = 'none';
                    scheduleContainer.style.display = 'block';
                }
            }, 5000);

            // Refresh the schedule periodically to get updates
            setInterval(function() {
                console.log('Refreshing schedule...');
                scheduleFrame.src = scheduleFrame.src;
            }, 3600000); // Refresh every hour
        }

        // Check for alerts
        async function checkForAlerts() {
            try {
                const response = await fetch(`/api/device/config?deviceId=${deviceId}`);
                const config = await response.json();

                if (config.alert) {
                    showAlertBanner(config.alert);
                } else {
                    hideAlertBanner();
                }
            } catch (error) {
                console.error('Error checking for alerts:', error);
            }
        }

        // Show alert banner
        function showAlertBanner(alert) {
            alertBanner.textContent = alert.name;
            alertBanner.className = 'alert-banner priority-' + (alert.priority || 'medium').toLowerCase();
            alertBanner.style.display = 'block';
            document.body.classList.add('has-alert');
        }

        // Hide alert banner
        function hideAlertBanner() {
            alertBanner.style.display = 'none';
            document.body.classList.remove('has-alert');
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            initSchedule();
            checkForAlerts();

            // Check for alerts every 5 minutes
            setInterval(checkForAlerts, 300000);
        });

        // Prevent context menu and text selection
        document.addEventListener('contextmenu', function(e) {
            e.preventDefault();
        });

        document.addEventListener('selectstart', function(e) {
            e.preventDefault();
        });

        // Disable common keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            // Disable Ctrl+T, Ctrl+N, Ctrl+W, Alt+F4, etc.
            if ((e.ctrlKey && ['t', 'n', 'w'].includes(e.key.toLowerCase())) ||
                (e.altKey && e.key === 'F4') ||
                e.key === 'F11') {
                e.preventDefault();
                return false;
            }
        });
    </script>
</body>
</html>
